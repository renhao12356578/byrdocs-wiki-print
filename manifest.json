{
  "manifest_version": 3,
  "name": "BYR Docs Wiki Print",
  "version": "0.1.0",
  "description": "为 BYR Docs 维基真题试卷页提供打印选项（概要信息、答案等）。",
  "homepage_url": "https://github.com/renhao12356578/byrdocs-wiki-print",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://wiki.byrdocs.org/exam/*",
        "https://*.wiki.byrdocs.org/exam/*",
        "http://localhost:4321/exam/*",
        "http://127.0.0.1:4321/exam/*"
      ],
      "js": ["content.js"],
      "css": ["ui.css", "print.css"],
      "run_at": "document_idle"
    }
  ]
}
